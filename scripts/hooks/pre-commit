#!/usr/bin/env bash
# Pre-commit hook: keep the wl-agent-toolkit SKILL.md copy in sync.
#
# One-time setup: git config core.hooksPath scripts/hooks
#
# .agents/skills/keypop/SKILL.md is a symlink to the canonical
# .cursor/skills/keypop/SKILL.md, so it never needs syncing. Only the
# sibling wl-agent-toolkit repo has a real copy — this regenerates it on
# disk (not auto-committed, since it's a separate repo) whenever the
# canonical file is staged.

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"

if git diff --cached --name-only | grep -qx ".cursor/skills/keypop/SKILL.md"; then
  "${REPO_ROOT}/scripts/sync-keypop-skill.sh"
fi
