#!/usr/bin/env bash
# Pre-commit hook: keep keypop's SKILL.md copies in sync.
#
# One-time setup: git config core.hooksPath scripts/hooks
#
# If the canonical .cursor/skills/keypop/SKILL.md is staged, regenerate the
# copies and stage the in-repo one (.agents/skills/keypop/SKILL.md — a real
# file, not a symlink, so raw GitHub fetches and Windows checkouts resolve
# it correctly). The wl-agent-toolkit copy lives in a separate repo, so
# it's updated on disk but not auto-committed — sync-keypop-skill.sh prints
# a reminder.

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"

if git diff --cached --name-only | grep -qx ".cursor/skills/keypop/SKILL.md"; then
  "${REPO_ROOT}/scripts/sync-keypop-skill.sh"
  git add "${REPO_ROOT}/.agents/skills/keypop/SKILL.md"
fi
